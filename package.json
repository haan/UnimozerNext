{
  "name": "unimozer-next",
  "private": true,
  "version": "0.15.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "cargo:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint .",
    "build:parser": "cd java-parser && gradle copyBridgeJar",
    "build:jshell": "cd jshell-bridge && gradle copyBridgeJar",
    "jshell:trace:summary": "node scripts/jshell-trace-summary.mjs",
    "sync:themes": "node scripts/sync-monaco-themes.cjs",
    "assets:logo-runtime": "node scripts/generate-logo-runtime-assets.mjs",
    "tauri": "tauri",
    "tauri dev": "tauri dev",
    "tauri:build": "tauri build --no-sign",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test": "npm run lint && npm run typecheck && npm run cargo:test && npm run test:unit",
    "test:java:parser": "cd java-parser && gradle test --no-daemon",
    "test:java:jshell": "cd jshell-bridge && gradle test --no-daemon",
    "test:java": "npm run test:java:parser && npm run test:java:jshell",
    "test:all": "npm run test && npm run test:java && npm run test:e2e"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.5",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "monaco-themes": "^0.4.8",
    "react": "^19.2.5",
    "react-color": "^2.19.3",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.2"
    }
  }
}
