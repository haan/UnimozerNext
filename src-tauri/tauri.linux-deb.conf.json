{
  "productName": "UnimozerNext",
  "bundle": {
    "createUpdaterArtifacts": false,
    "targets": ["deb"],
    "fileAssociations": [
      {
        "ext": ["umz"],
        "name": "Unimozer Next Project",
        "description": "Unimozer Next Project File",
        "mimeType": "application/x-unimozer-project"
      }
    ],
    "resources": {
      "../resources/jdk/linux-x64": "jdk/linux-x64",
      "../resources/java-parser/parser-bridge.jar": "java-parser/parser-bridge.jar",
      "../resources/jshell-bridge/jshell-bridge.jar": "jshell-bridge/jshell-bridge.jar",
      "../resources/jdtls/plugins": "jdtls/plugins",
      "../resources/jdtls/config_linux": "jdtls/config_linux",
      "../resources/jdtls/features": "jdtls/features"
    },
    "linux": {
      "deb": {
        "postInstallScript": "linux/deb/postinst",
        "postRemoveScript": "linux/deb/postrm",
        "files": {
          "/usr/share/mime/packages/com.unimozer.next.xml": "linux/mime/com.unimozer.next.xml"
        }
      }
    }
  }
}
