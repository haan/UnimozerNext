{
  "productName": "UnimozerNext",
  "bundle": {
    "targets": ["appimage"],
    "fileAssociations": [
      {
        "ext": ["umz"],
        "name": "Unimozer Next Project",
        "description": "Unimozer Next Project File",
        "mimeType": "application/x-unimozer-project"
      }
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/unimozer-next/resources/jdk/linux-x64": "../resources/jdk/linux-x64",
          "/usr/share/unimozer-next/resources/java-parser/parser-bridge.jar": "../resources/java-parser/parser-bridge.jar",
          "/usr/share/unimozer-next/resources/jshell-bridge/jshell-bridge.jar": "../resources/jshell-bridge/jshell-bridge.jar",
          "/usr/share/unimozer-next/resources/jdtls": "../resources/jdtls"
        }
      }
    }
  }
}
